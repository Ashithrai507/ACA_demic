   "source": [
    "import nltk\n",
    "from nltk.corpus import wordnet as wn\n",
    "\n",
    "nltk.download('wordnet')\n",
    "\n",
    "w=\"active\"\n",
    "syn={l.name() for s in wn.synsets(w) for l in s.lemmas()}\n",
    "ant={l.antonyms()[0].name() for s in wn.synsets(w) for l in s.lemmas() if l.antonyms()}\n",
    "\n",
    "print(w, \"\\nSyn:\", syn, \"\\nAnt:\", ant)"
   ]
